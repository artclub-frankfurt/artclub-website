---
import { Picture } from 'astro:assets';
import { getEntry } from 'astro:content';
import heroCampus from '../assets/hero-campus.jpg';

const home = await getEntry('site', 'home');
const title = home?.data.heroTitle ?? 'Connecting people through art.';
const subtitle = home?.data.heroSubtitle ?? 'Student initiative at Goethe University, Frankfurt.';
---
<section class="home-hero">
  <Picture
    src={heroCampus}
    alt="Goethe University Westend campus, with reflecting pool and bronze sculpture in the foreground."
    widths={[480, 800, 1100, 1240]}
    sizes="100vw"
    formats={['avif', 'webp']}
    quality={82}
    loading="eager"
    fetchpriority="high"
    decoding="async"
    class="home-hero__bg"
    pictureAttributes={{ class: 'home-hero__picture' }}
  />
  <div class="home-hero__overlay" aria-hidden="true"></div>
  <div class="home-hero__content">
    <h1 class="home-hero__title">{title}</h1>
    <p class="home-hero__subtitle">{subtitle}</p>
  </div>
</section>

<style>
  .home-hero {
    position: relative;
    width: 100%;
    aspect-ratio: 21 / 9;
    overflow: hidden;
    background: var(--color-ink);
  }

  .home-hero__picture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .home-hero__bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 80%;
  }

  .home-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(20, 20, 20, 0.05) 0%,
      rgba(20, 20, 20, 0.28) 55%,
      rgba(20, 20, 20, 0.6) 100%
    );
  }

  .home-hero__content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2.5rem 1.5rem 3rem;
    color: #fff;
  }

  .home-hero__title {
    font-family: var(--font-serif);
    font-size: var(--text-display-xl);
    font-weight: 400;
    line-height: 1.06;
    letter-spacing: -0.005em;
    max-width: 18ch;
    margin: 0 0 0.85rem;
    color: #fff;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.25);
  }

  .home-hero__subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 1023px) {
    .home-hero { aspect-ratio: 16 / 9; }
    .home-hero__title { font-size: 2.75rem; }
  }

  @media (max-width: 639px) {
    .home-hero { aspect-ratio: 3 / 4; }
    .home-hero__title {
      font-size: 2.125rem;
      max-width: 14ch;
    }
    .home-hero__subtitle { font-size: 0.9375rem; }
  }
</style>
