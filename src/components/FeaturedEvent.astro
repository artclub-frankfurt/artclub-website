---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { partitionEvents, formatEventEyebrow } from '../lib/events';

const all = await getCollection('events');
const withSlug = all.map(e => ({ ...e, slug: e.id }));
const { upcoming } = partitionEvents(withSlug);
const next = upcoming[0];
---
<section class="featured-event">
  <div class="featured-event__inner">
    <p class="eyebrow featured-event__eyebrow">Upcoming</p>
    {next ? (
      <>
        {next.data.coverImage && (
          <figure class="featured-event__figure">
            <Image
              src={next.data.coverImage}
              alt={next.data.coverImageAlt ?? `Poster for ${next.data.title}`}
              widths={[280, 400, 560, 720]}
              sizes="(min-width: 640px) 360px, 60vw"
              formats={['avif', 'webp']}
              quality={82}
              class="featured-event__cover"
            />
            {next.data.coverImageCredit && (
              <figcaption class="featured-event__credit">{next.data.coverImageCredit}</figcaption>
            )}
          </figure>
        )}
        <h2 class="featured-event__title">{next.data.title}</h2>
        <p class="featured-event__meta">{formatEventEyebrow(next.data.date, next.data.time)}</p>
        {next.data.subtitle && (
          <p class="featured-event__subtitle">{next.data.subtitle}</p>
        )}
        <div class="featured-event__ctas">
          <a
            href={next.data.lumaUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Register on Luma
          </a>
          <a href="/events" class="link-chrome">See all events →</a>
        </div>
      </>
    ) : (
      <p class="featured-event__empty">No upcoming events right now — check back soon.</p>
    )}
  </div>
</section>

<style>
  .featured-event {
    background: var(--color-canvas);
    padding: 5rem 1.5rem 5.5rem;
  }

  .featured-event__inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .featured-event__eyebrow {
    margin: 0 0 1rem;
  }

  .featured-event__figure {
    margin: 0 auto 1.75rem;
    width: fit-content;
    max-width: 100%;
  }

  /* Same image works for portrait and landscape posters: width capped at
   * 360px and height at 280px so portraits don't dominate the section. */
  .featured-event__cover {
    display: block;
    max-width: 360px;
    max-height: 280px;
    width: auto;
    height: auto;
    margin: 0 auto;
  }

  .featured-event__credit {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.8125rem;
    color: var(--color-ink-3);
    text-align: center;
    margin: 0.65rem 0 0;
    line-height: 1.4;
  }

  .featured-event__title {
    font-family: var(--font-serif);
    font-size: var(--text-h1);
    font-weight: 400;
    line-height: 1.15;
    margin: 0 0 0.65rem;
    color: var(--color-ink);
  }

  .featured-event__meta {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--color-ink-2);
    margin: 0 0 0.35rem;
    letter-spacing: 0.01em;
  }

  .featured-event__subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--color-ink-2);
    margin: 0 0 2rem;
  }

  .featured-event__meta:last-of-type { margin-bottom: 2rem; }

  .featured-event__ctas {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .featured-event__empty {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-ink-2);
    margin: 0;
  }

  @media (min-width: 640px) {
    .featured-event__ctas {
      flex-direction: row;
      justify-content: center;
      gap: 2.25rem;
    }
  }
</style>
