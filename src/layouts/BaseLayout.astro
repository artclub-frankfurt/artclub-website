---
import { siteConfig } from '../lib/siteConfig';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const fullTitle = title ? `${title} — ${siteConfig.siteName}` : siteConfig.siteName;
const wordmarkText = siteConfig.siteName.toUpperCase();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="min-h-screen flex flex-col">
    <header>
      <div class="wordmark-band">
        <div class="wordmark-band__inner">
          <a href="/" class="wordmark">{wordmarkText}</a>
          <button
            id="nav-toggle"
            type="button"
            class="hamburger"
            aria-label="Toggle navigation menu"
            aria-expanded="false"
            aria-controls="primary-nav"
          >
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
      <div class="hairline"></div>

      <nav id="primary-nav" class="nav-band" data-state="closed" aria-label="Primary">
        <div class="nav-band__inner">
          <ul class="nav-list">
            <li><a href="/">Home</a></li>
            <li><a href="/events">Events</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
          <a
            href={siteConfig.googleFormUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline nav-band__cta"
          >
            Become a Member
          </a>
        </div>
        <div class="hairline"></div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer>
      <div class="hairline"></div>
      <div class="footer-band">
        <div class="footer-band__inner">
          <p class="footer-copyright">© {new Date().getFullYear()} {siteConfig.siteName}</p>
          <div class="footer-links">
            <a href={`mailto:${siteConfig.contactEmail}`}>{siteConfig.contactEmail}</a>
            <a href={siteConfig.socialLinks.instagram} target="_blank" rel="noopener noreferrer">Instagram</a>
          </div>
        </div>
      </div>
    </footer>

    <style>
      .wordmark-band__inner,
      .nav-band__inner,
      .footer-band__inner {
        max-width: 1200px;
        margin: 0 auto;
        padding-left: 1.5rem;
        padding-right: 1.5rem;
      }

      /* Wordmark band — centered serif wordmark; hamburger is mobile-only and absolute-right */
      .wordmark-band__inner {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-top: 1.25rem;
        padding-bottom: 1.25rem;
      }

      .hamburger {
        display: none;
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        width: 2.5rem;
        height: 2.5rem;
        padding: 0;
        background: transparent;
        border: 0;
        cursor: pointer;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 5px;
      }
      .hamburger span {
        display: block;
        width: 1.25rem;
        height: 1px;
        background: var(--color-ink);
      }

      /* Nav band */
      .nav-band__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        padding-top: 0.875rem;
        padding-bottom: 0.875rem;
      }
      .nav-list {
        display: flex;
        align-items: center;
        gap: 3rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .nav-list a {
        font-family: var(--font-sans);
        font-size: var(--text-nav);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: var(--tracking-nav);
        color: var(--color-ink);
        transition: color 150ms ease;
      }
      .nav-list a:hover { color: var(--color-burgundy); }
      .nav-band__cta { padding: 0.7rem 1.25rem; }

      /* Footer */
      .footer-band__inner {
        padding-top: 1.75rem;
        padding-bottom: 1.75rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
      }
      .footer-copyright {
        font-family: var(--font-serif);
        font-size: var(--text-meta);
        color: var(--color-ink-2);
        margin: 0;
      }
      .footer-links {
        display: flex;
        gap: 1.75rem;
      }
      .footer-links a {
        font-family: var(--font-sans);
        font-size: var(--text-nav);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: var(--tracking-nav);
        color: var(--color-ink-2);
        transition: color 150ms ease;
      }
      .footer-links a:hover { color: var(--color-burgundy); }

      @media (min-width: 768px) {
        .footer-band__inner {
          flex-direction: row;
          align-items: center;
          justify-content: space-between;
        }
      }

      /* Mobile (< 768px): nav-band collapses behind a hamburger */
      @media (max-width: 767px) {
        .hamburger { display: flex; }

        .nav-band { display: none; }
        .nav-band[data-state="open"] { display: block; }

        .nav-band__inner {
          flex-direction: column;
          align-items: stretch;
          gap: 0;
          padding-top: 0;
          padding-bottom: 0;
        }
        .nav-list {
          flex-direction: column;
          align-items: stretch;
          gap: 0;
        }
        .nav-list li + li {
          border-top: 1px solid var(--color-hairline);
        }
        .nav-list a {
          display: block;
          padding: 1rem 0;
          text-align: center;
        }
        .nav-band__cta {
          margin: 1rem auto 1.25rem;
        }
      }
    </style>

    <script is:inline>
      const toggle = document.getElementById('nav-toggle');
      const nav = document.getElementById('primary-nav');
      if (toggle && nav) {
        toggle.addEventListener('click', () => {
          const willOpen = nav.getAttribute('data-state') !== 'open';
          nav.setAttribute('data-state', willOpen ? 'open' : 'closed');
          toggle.setAttribute('aria-expanded', String(willOpen));
        });
      }
    </script>
  </body>
</html>
