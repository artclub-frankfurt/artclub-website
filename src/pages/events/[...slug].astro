---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InstagramGrid from '../../components/InstagramGrid.astro';
import { formatEventEyebrow } from '../../lib/events';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map(event => ({
    params: { slug: event.id },
    props: { event },
  }));
}

interface Props {
  event: CollectionEntry<'events'>;
}
const { event } = Astro.props;
const { Content } = await render(event);

const eyebrow = formatEventEyebrow(event.data.date, event.data.time);
const description = event.data.subtitle ?? `Event details for ${event.data.title}.`;
---
<BaseLayout title={event.data.title} description={description}>
  <article class="event-article">
    <header class="event-article__header">
      <p class="eyebrow event-article__label">Event</p>
      <p class="eyebrow event-article__date">{eyebrow}</p>
      <h1 class="event-article__title">{event.data.title}</h1>
      {event.data.subtitle && (
        <p class="event-article__subtitle">{event.data.subtitle}</p>
      )}
      <a
        href={event.data.lumaUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary event-article__cta"
      >
        Register on Luma →
      </a>
    </header>

    <div class="hairline event-article__divider"></div>

    <div class="event-article__body markdown-prose">
      <Content />
    </div>
  </article>

  {event.data.instagramPosts.length > 0 && (
    <InstagramGrid posts={event.data.instagramPosts} />
  )}
</BaseLayout>

<style>
  .event-article {
    max-width: 720px;
    margin: 0 auto;
    padding: 4.5rem 1.5rem 3rem;
  }

  .event-article__header {
    text-align: center;
  }

  .event-article__label {
    margin: 0 0 0.5rem;
  }

  .event-article__date {
    color: var(--color-ink-2);
    margin: 0 0 1.4rem;
  }

  .event-article__title {
    font-family: var(--font-serif);
    font-size: var(--text-display);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0 0 0.85rem;
  }

  .event-article__subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--color-ink-2);
    margin: 0 0 1.75rem;
  }

  .event-article__cta {
    margin-top: 0.25rem;
  }

  .event-article__divider {
    margin: 3rem 0 2.5rem;
  }

  @media (max-width: 640px) {
    .event-article {
      padding: 3rem 1.25rem 2.5rem;
    }
    .event-article__title {
      font-size: 2.25rem;
    }
  }
</style>
