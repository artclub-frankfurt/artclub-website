---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Page not found"
  description="This page doesn't exist — return to the home page or browse upcoming events."
>
  <section class="not-found">
    <div class="not-found__inner">
      <p class="eyebrow">Error 404</p>
      <h1 class="not-found__title">Page not found.</h1>
      <p class="not-found__body">
        The page you were looking for has moved, or it never existed.
      </p>
      <div class="not-found__links">
        <a href="/" class="link-chrome">← Back to home</a>
        <a href="/events" class="link-chrome">See all events →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    background: var(--color-canvas);
    padding: 6rem 1.5rem 7rem;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .not-found__inner {
    max-width: 620px;
    text-align: center;
  }

  .not-found__title {
    font-family: var(--font-serif);
    font-size: var(--text-display);
    font-weight: 400;
    line-height: 1.1;
    margin: 1rem 0 1.25rem;
    color: var(--color-ink);
  }

  .not-found__body {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--color-ink-2);
    margin: 0 0 2.25rem;
    line-height: 1.6;
  }

  .not-found__links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .not-found__links {
      flex-direction: row;
      justify-content: center;
      gap: 2.25rem;
    }
  }
</style>
